# Note: All the variables to this image are optional.
# See README for more information.
# To use, copy this file to 'ollama.env' and uncomment/set your values.

# API key for authenticating requests to the Ollama server.
# - Auto-generated on first start if not set. Shown in container logs.
# - All API requests (except health check at /) require this key.
# - Keep this secret — it has full access to the Ollama API.
# - Use 'docker exec <container> ollama_manage --showkey' to display it.
# - Use 'docker exec <container> ollama_manage --getkey' in scripts.
# OLLAMA_API_KEY=my-secret-key

# TCP port for the Ollama API (default: 11434)
# OLLAMA_PORT=11434

# Hostname or IP address shown in startup info and 'ollama_manage --showkey' output.
# Set this if you have a domain name pointing to this server, e.g. ollama.example.com
# If not set, the server's public IP is detected automatically.
# OLLAMA_HOST=ollama.example.com

# Enable debug logging (default: not set)
# Set to 1 to enable verbose debug output.
# OLLAMA_DEBUG=1

# -----------------------------------------------------------------------
# Models to pull on first start (comma-separated, optional)
# These are pulled once when the container is first initialized.
# You can also pull models at any time using 'ollama_manage --pull'.
# Examples: llama3.2:3b  qwen2.5:7b  mistral:7b  phi4:14b  gemma3:12b
# -----------------------------------------------------------------------

# OLLAMA_MODELS=llama3.2:3b

# -----------------------------------------------------------------------
# Advanced tuning (optional)
# Leave unset to use Ollama's built-in defaults.
# -----------------------------------------------------------------------

# Maximum number of models kept loaded in memory simultaneously (default: 1)
# OLLAMA_MAX_LOADED_MODELS=1

# Number of parallel request slots per model (default: auto)
# OLLAMA_NUM_PARALLEL=1

# Default context window size in tokens (default: 2048)
# OLLAMA_CONTEXT_LENGTH=4096